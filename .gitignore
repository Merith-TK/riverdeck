# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool, specifically when used with LiteIDE
*.out

# Dependency directories (uncomment if using vendor)
# vendor/

# Go workspace file
go.work

# Go build cache
.cache/

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Logs
*.log

# Temporary files
*.tmp
*.temp

# Build artifacts
dist/
build/

# Generated icon PNGs (regenerated by `mage icons`)
resources/icons/

# Windows resource files (regenerated by `mage winres`)
*.syso

# Probe output files (date-stamped JSONs captured from real hardware)
*_[0-9][0-9][0-9][0-9][0-9][0-9][0-9][0-9].json
testdata/

# Persistent identity files (generated per-machine, not portable)
.mcp-device-id
**/.mcp-device-id
.sim-device-id

# Configuration / runtime data that may contain sensitive info
# (auth tokens, device state, etc. live under .riverdeck/.packages/*/data)
# The Lua source files inside .riverdeck/ ARE tracked; data dirs are not.
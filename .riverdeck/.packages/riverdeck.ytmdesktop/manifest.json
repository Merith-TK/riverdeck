{
	"id": "riverdeck.ytmdesktop",
	"name": "YTM Desktop",
	"version": "1.0.0",
	"description": "YouTube Music Desktop App companion integration via the Companion Server API v1",
	"provides": {
		"libraries": [
			"lib/ytm.lua"
		],
		"templates": [
			{
				"id": "pair",
				"label": "Pair",
				"script": "templates/pair.lua",
				"description": "Manage YTM Desktop pairing. Press to initiate or re-initiate pairing."
			},
			{
				"id": "play_pause",
				"label": "Play/Pause",
				"script": "templates/play_pause.lua",
				"description": "Toggle playback in YTM Desktop."
			},
			{
				"id": "next",
				"label": "Next",
				"script": "templates/next.lua",
				"description": "Skip to the next track."
			},
			{
				"id": "prev",
				"label": "Previous",
				"script": "templates/prev.lua",
				"description": "Go back to the previous track."
			},
			{
				"id": "like",
				"label": "Like",
				"script": "templates/like.lua",
				"description": "Toggle like on the current track."
			},
			{
				"id": "shuffle",
				"label": "Shuffle",
				"script": "templates/shuffle.lua",
				"description": "Send a shuffle toggle command."
			},
			{
				"id": "thubnail",
				"label": "Thumbnail",
				"script": "templates/thumbnail.lua",
				"description": "Show the current track's thumbnail.)"
			}
		]
	},
	"requires": []
}